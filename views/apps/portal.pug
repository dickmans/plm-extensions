extends ../framework/layout

block head
    
    link(rel='stylesheet', href='/stylesheets/apps/portal.css')
    link(rel='stylesheet', href='/stylesheets/custom/portal.css')

    script(src='/javascripts/apps/portal.js')
    script(src='/javascripts/custom/portal.js')

block body

    body.surface-level-1.not-attachments.no-bom

        #header.dark
            #header-logo
            #header-title= title
            #header-subtitle
            #header-toolbar
                .button.with-toggle.toggle-on.filled#toggle-search(title='Toggle search panel on/off') Search Panel
                .button.with-toggle.toggle-off#toggle-bom(title='Toggle BOM panel on/off') BOM
                .button.with-toggle.toggle-on#toggle-details(title='Toggle Details panel on/off') Details
                .button.with-toggle.toggle-on#toggle-attachments(title='Toggle Files panel on/off') Files
                #header-avatar
        
        #main.screen

            .surface-level-2#search
            .surface-level-2#recents

            .surface-level-1.hidden#bom
            .surface-level-1.hidden#viewer.viewer
            .surface-level-2.hidden#details
            .surface-level-2.hidden#attachments