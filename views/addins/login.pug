extends ../framework/addins

block head

    link(rel='stylesheet', href='/stylesheets/addins/login.css')
    link(rel='stylesheet', href='/stylesheets/custom/addins.css')
    
    script(src='/javascripts/addins/login.js')
    script(src='/javascripts/custom/addins.js')

block body 

    body.addin

        .screen.no-header.surface-level-2
            #validation 
                #validation-title Logging in to 
                    br 
                    |Vault PLM
            .error#error-1.hidden.surface-level-2
                .icon.icon-important
                .text Your server is not configured properly. Please contact your Administrator.
            .error#error-2.hidden.surface-level-2
                .icon.icon-important
                .text Your Autodesk account must be linked to one Vault user account. Please contact your Vault administrator.