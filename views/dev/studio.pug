extends ../framework/layout

block head
    
    link(rel='stylesheet', href='/stylesheets/dev/studio.css')
    script(src='/javascripts/dev/studio.js')
    script(src='/javascripts/framework/registry.js')
    script.
        config = !{JSON.stringify(config)};

block body

    body.surface-level-1

        #header.dark
            #header-logo
            #header-title= title
            #header-toolbar
                #toggle-layout.button Toggle Layout
                #header-avatar
        
        #main.screen

            #library.surface-level-1.pos-abs-left 
                #library-title Select Panel Type
                #library-list.pos-abs-bottom.no-scrollbar

            #settings.surface-level-2

                #settings-header
                    #settings-title
                    #run.button.default.with-icon.icon-start Run
                #settings-description
                #settings-function
                #settings-inputs
                #settings-json
                    #settings-json-title JSON String
                    textarea#settings-json-string.surface-level-4
                    #settings-json-description Copy this JSON string to your settings file to adjust the applications supporting direct panel configuration

            #panel.surface-level-1
                #panel-message Select a panel type to the left, set the panel's properties and then click Apply in order to see the preview of the given panel here.

        #create.dialog